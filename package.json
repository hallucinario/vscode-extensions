{
  "name": "jsonl-viewer",
  "displayName": "JSONL Viewer",
  "description": "Rich JSONL file viewer with Tree View explorer and interactive table Webview",
  "publisher": "hallucinario",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": ["Visualization", "Other"],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:jsonl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jsonl",
        "aliases": ["JSONL", "JSON Lines"],
        "extensions": [".jsonl", ".ndjson"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "jsonlViewer.refresh",
        "title": "Refresh",
        "category": "JSONL Viewer",
        "icon": "$(refresh)"
      },
      {
        "command": "jsonlViewer.openTable",
        "title": "Open Table View",
        "category": "JSONL Viewer",
        "icon": "$(table)"
      },
      {
        "command": "jsonlViewer.copyValue",
        "title": "Copy Value",
        "category": "JSONL Viewer"
      },
      {
        "command": "jsonlViewer.copyLine",
        "title": "Copy Line JSON",
        "category": "JSONL Viewer"
      },
      {
        "command": "jsonlViewer.goToLine",
        "title": "Go to Line",
        "category": "JSONL Viewer"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "jsonlViewer.entries",
          "name": "JSONL Entries",
          "when": "resourceExtname == .jsonl || resourceExtname == .ndjson"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "jsonlViewer.refresh",
          "when": "view == jsonlViewer.entries",
          "group": "navigation@1"
        },
        {
          "command": "jsonlViewer.openTable",
          "when": "view == jsonlViewer.entries",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "jsonlViewer.copyValue",
          "when": "view == jsonlViewer.entries",
          "group": "jsonlViewer@1"
        },
        {
          "command": "jsonlViewer.copyLine",
          "when": "view == jsonlViewer.entries && viewItem =~ /^(entry|error)$/",
          "group": "jsonlViewer@2"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonlViewer.copyValue",
          "when": "false"
        },
        {
          "command": "jsonlViewer.copyLine",
          "when": "false"
        },
        {
          "command": "jsonlViewer.goToLine",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "JSONL Viewer",
      "properties": {
        "jsonlViewer.maxDisplayedLines": {
          "type": "number",
          "default": 5000,
          "description": "Maximum number of JSONL entries to display.",
          "scope": "resource"
        },
        "jsonlViewer.previewKeyCount": {
          "type": "number",
          "default": 3,
          "description": "Number of key-value pairs shown in entry preview.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist out .vscode-test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "lint": "eslint src test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "bundle": "node esbuild.js",
    "bundle:watch": "node esbuild.js --watch",
    "bundle:prod": "node esbuild.js --production",
    "compile:tests": "tsc -p tsconfig.json",
    "test:integration": "pnpm run bundle && pnpm run compile:tests && vscode-test",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test:unit && pnpm run bundle",
    "package": "pnpm run check && pnpm exec vsce package --out dist-vsix"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "22.15.3",
    "@types/vscode": "1.100.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.8.1",
    "esbuild": "0.27.5",
    "eslint": "10.4.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "vitest": "4.1.6"
  }
}
